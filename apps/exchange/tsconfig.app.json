{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@agce/types": ["../../packages/types/src/index.ts"],
      "@agce/config": ["../../packages/config/src/index.ts"],
      "@agce/ui": ["../../packages/ui/src/index.ts"],
      "@agce/hooks": ["../../packages/hooks/src/index.ts"]
    }
  },
  "include": ["src"]
}
