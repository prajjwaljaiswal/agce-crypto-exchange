# Instance (india | abudhabi | dubai | global) — selected at build time
VITE_INSTANCE=global

# Production gateway URL — leave empty in dev so requests flow through
# Vite's dev proxy (bypasses CORS). Set this for production builds.
VITE_API_BASE_URL=

# Dev-only: override the target the Vite proxy forwards /api and /healthz to.
# Defaults to http://192.168.1.16:8080 when unset.
VITE_API_PROXY_TARGET=http://192.168.1.16:8080
