          "name": "Order Book — depth",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/binance/depth?symbol={{symbol}}&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "binance", "depth"],
              "query": [
                {
                  "key": "symbol",
                  "value": "{{symbol}}",
                  "description": "Trading pair"
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "5, 10, 20, 50, 100, 500, 1000, 5000"
                }
              ]
            },
            "description": "Order book snapshot. Use to seed the order book widget before subscribing to the live `depth` channel over Socket.IO."
          },
          "response": []
        },
        {
          "name": "Recent Trades",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/binance/trades?symbol={{symbol}}&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "binance", "trades"],
              "query": [
                {
                  "key": "symbol",
                  "value": "{{symbol}}",
                  "description": "Trading pair"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Default 500, max 1000"
                }
              ]
