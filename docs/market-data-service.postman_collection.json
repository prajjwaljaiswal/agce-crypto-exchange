        {
          "name": "Klines — candlesticks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/binance/klines?symbol={{symbol}}&interval=1m&limit=500",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "binance", "klines"],
              "query": [
                {
                  "key": "symbol",
                  "value": "{{symbol}}"
