                {
                  "key": "interval",
                  "value": "1m",
                  "description": "1s, 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M"
                },
                {
                  "key": "limit",
                  "value": "500",
                  "description": "Default 500, max 1000"
                }
              ]
            },
            "description": "Historical OHLCV. Use to render the price chart, then subscribe to the live `kline` channel with the same interval."
          },
          "response": []
        }
      ]
    },
