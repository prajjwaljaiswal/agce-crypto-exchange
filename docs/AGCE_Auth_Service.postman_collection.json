            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"signup\",\n  \"identifier\": \"+911234567890\",\n  \"otp\": \"{{otp}}\",\n  \"password\": \"SecurePass123\",\n  \"jurisdiction\": \"{{jurisdiction}}\"\n}"
