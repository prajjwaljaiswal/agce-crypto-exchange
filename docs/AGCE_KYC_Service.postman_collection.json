                  "  vendor_data: pm.environment.get('userId') || 'test-user'",
                  "};",
                  "pm.variables.set('webhookBody', JSON.stringify(body));",
                  "pm.variables.set('webhookSig', 'this-is-a-bad-signature');",
                  "pm.variables.set('webhookTs', ts.toString());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401', () => pm.response.to.have.status(401));",
