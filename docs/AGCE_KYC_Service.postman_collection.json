              "raw": "{\n  \"jurisdiction\": \"{{jurisdiction}}\",\n  \"firstName\": \"Abhay\",\n  \"lastName\": \"Bagoriya\",\n  \"email\": \"abhay@example.com\",\n  \"phone\": \"+911234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrlKyc}}/api/v1/kyc/session",
              "host": ["{{baseUrlKyc}}"],
              "path": ["api", "v1", "kyc", "session"]
