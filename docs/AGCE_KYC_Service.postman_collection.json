        {
          "name": "Webhook: Bad Signature (should fail)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Intentionally use a wrong signature",
                  "const ts = Math.floor(Date.now() / 1000);",
                  "const body = {",
                  "  session_id: pm.environment.get('kycSessionId') || 'test-session-id',",
                  "  status: 'Approved',",
